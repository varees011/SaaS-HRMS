NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrms?schema=public
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=saas-hrms-api
JWT_AUDIENCE=saas-hrms-web
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
MFA_ISSUER=SaaS HRMS
MFA_ENCRYPTION_KEY=replace-with-exactly-64-hexadecimal-characters-0000000000000000
AUTH_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_FROM_EMAIL=your-smtp-user@example.com
SMTP_FROM_NAME=VentureSoft HRMS
SUPER_ADMIN_TENANT_CODE=platform
SUPER_ADMIN_EMAIL=superadmin@venturesoft.ai
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
RESET_SUPER_ADMIN_PASSWORD=false
RBAC_SEED_TENANT_CODE=venturesoft
RBAC_SEED_TENANT_NAME=VentureSoft.AI
RBAC_SEED_PASSWORD=replace-with-a-strong-temporary-password
